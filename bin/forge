#!/usr/bin/env bash
# Thin wrapper: resolve symlinks so /usr/local/bin/forge -> repo/bin/forge.py works.
set -euo pipefail
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  case "$TARGET" in
    /*) SOURCE="$TARGET" ;;
    *)  SOURCE="$DIR/$TARGET" ;;
  esac
done
HERE="$(cd -P "$(dirname "$SOURCE")" && pwd)"
exec python3 "$HERE/forge.py" "$@"
